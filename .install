#!/bin/bash

# Abort on error
set -e

update() {
    local OS=$(uname -s)

    if [ "$OS" = "Darwin" ]; then
        brew update && brew upgrade
    elif [ "$OS" = "Linux" ]; then
        if [ -f /etc/os-release ]; then
            . /etc/os-release
            case $ID in
                debian|ubuntu)
                    sudo apt-get update -y && sudo apt-get upgrade -y
                    ;;
                arch)
                    sudo pacman -Syu --noconfirm
                ;;
                endeavouros)
                    if command -v yay >/dev/null 2>&1; then
                        yay -Syu --noconfirm
                    else
                        sudo pacman -Syu --noconfirm
                    fi
                    ;;
                opensuse-tumbleweed|opensuse-leap|opensuse)
                    sudo zypper refresh && sudo zypper dup --no-confirm
                    ;;
                *)
                    echo "This is a different Linux distribution: $ID"
                    ;;
            esac
        fi
    else
        echo "Could not identify Operating System."
    fi
}

install_packages() {
    local OS=$(uname -s)

    if [ "$OS" = "Darwin" ]; then
        # Check if brew exists, though we install it later
        if command -v brew >/dev/null 2>&1; then
            brew install "$@"
        fi
    elif [ "$OS" = "Linux" ]; then
        if [ -f /etc/os-release ]; then
            . /etc/os-release
            case $ID in
                debian|ubuntu)
                    sudo apt-get install -y "$@"
                    ;;
                arch)
                    sudo pacman -S --noconfirm "$@"
                    ;;
                endeavouros)
                    if command -v yay >/dev/null 2>&1; then
                        yay -S --noconfirm "$@"
                    else
                        sudo pacman -S --noconfirm "$@"
                    fi
                    ;;
                opensuse-tumbleweed|opensuse-leap|opensuse)
                    sudo zypper install --no-confirm "$@"
                    ;;
                *)
                    echo "This is a different Linux distribution: $ID"
                    ;;
            esac
        fi
    else
        echo "Could not identify Operating System."
    fi
}

chzsh() {
    local OS=$(uname -s)
    if [ "$OS" = "Linux" ]; then
        if [ -z "$CI" ]; then
            sudo chsh -s $(which zsh) $(whoami)
        fi
    fi
}

cask() {
    local OS=$(uname -s)
    if [ "$OS" = "Darwin" ]; then
        if command -v brew >/dev/null 2>&1; then
            brew install --cask "$@"
        fi
    fi
}

homebrew() {
    local OS=$(uname -s)
    if [ "$OS" = "Darwin" ]; then
        if ! command -v brew >/dev/null 2>&1; then
            NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        fi
    fi
}

get_os_name() {
    local OS=$(uname -s)

    if [ "$OS" = "Darwin" ]; then
        echo "macos"
    elif [ "$OS" = "Linux" ]; then
        if [ -f /etc/os-release ]; then
            . /etc/os-release
            echo $ID
        fi
    else
        echo "unknown"
    fi 
}

clone_or_update() {
    local repo_url=$1
    local target_dir=$2
    if [ ! -d "$target_dir" ]; then
        git clone "$repo_url" "$target_dir"
    else
        echo "$target_dir already exists. Pulling latest..."
        git -C "$target_dir" pull || true
    fi
}

after_install() {
    # Setup dotfiles
    homebrew
    
    update

    # MOVE TO HOME
    pushd $HOME

    install_packages git
    
    if [ ! -d ".git" ]; then
        git init
        git remote add origin https://github.com/mfield4/dotfiles
        git pull --set-upstream origin main -f || true
    fi

    # Install initial packages
    local OS_NAME=$(get_os_name)

    # Some distributions like ubuntu use the same packages as debian conceptually, but usually we just check the direct ID
    local PKG_FILE="$HOME/.config/dotfiles/$OS_NAME/.packages"
    if [ -f "$PKG_FILE" ]; then
        source "$PKG_FILE"
        if [ -n "$PACKAGES" ]; then
            install_packages $PACKAGES
        fi
        if [ -n "$CASKS" ]; then
            cask $CASKS
        fi
    else
        echo "Warning: no package file found at $PKG_FILE"
    fi

    # zsh setup
    clone_or_update https://github.com/ohmyzsh/ohmyzsh.git "$HOME/.oh-my-zsh"
    clone_or_update https://github.com/zsh-users/zsh-completions "$HOME/.oh-my-zsh/custom/plugins/zsh-completions"
    clone_or_update https://github.com/zsh-users/zsh-syntax-highlighting.git "$HOME/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting"
    clone_or_update https://github.com/zsh-users/zsh-autosuggestions "$HOME/.oh-my-zsh/custom/plugins/zsh-autosuggestions"
    clone_or_update https://github.com/zsh-users/zsh-history-substring-search "$HOME/.oh-my-zsh/custom/plugins/zsh-history-substring-search"
    
    chzsh

    # MOVE BACK TO START
    popd
}

after_install
